#!/usr/bin/env sh
# Versioned pre-push hook.
# Install via: python scripts/install_git_hooks.py (one-time per clone).
#
# Per the git pre-push protocol:
#   args  : <remote_name> <remote_url>
#   stdin : one line per pushed ref — `<local_ref> <local_sha> <remote_ref> <remote_sha>`
#
# We invoke the LLM reviewer whenever the pushed range contains changed
# files. Dispatch markdown files are passed as optional canonical context,
# but they are not required to trigger review.

set -e

REMOTE_NAME="$1"
ZERO_SHA="0000000000000000000000000000000000000000"

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

while read -r local_ref local_sha remote_ref remote_sha; do
    # Skip branch deletes
    if [ "$local_sha" = "$ZERO_SHA" ]; then
        continue
    fi

    # Determine diff range. New branch (no remote tracking) → diff vs origin/main.
    if [ "$remote_sha" = "$ZERO_SHA" ]; then
        if git rev-parse --verify --quiet origin/main >/dev/null; then
            DIFF_RANGE="origin/main..$local_sha"
        else
            DIFF_RANGE="$local_sha"
        fi
    else
        DIFF_RANGE="$remote_sha..$local_sha"
    fi

    # No `|| true` fallback: if `git diff` itself fails (corrupt repo,
    # invalid range), `set -e` aborts the hook. Empty result on no
    # matches is normal exit-0 — silent fallback would hide real errors.
    CHANGED_FILES=$(git diff --name-only "$DIFF_RANGE")

    if [ -z "$CHANGED_FILES" ]; then
        continue
    fi

    BRANCH_NAME=$(git rev-parse --abbrev-ref HEAD)

    echo "[pre-push] changed file(s) in push range - invoking LLM reviewer..."

    if ! command -v python >/dev/null 2>&1; then
        echo "[pre-push] ERROR: python not found on PATH; cannot run reviewer." >&2
        echo "[pre-push] bypass with: git push --no-verify (not recommended)" >&2
        exit 1
    fi

    echo "$CHANGED_FILES" | python scripts/pre_push_review.py \
        --branch "$BRANCH_NAME" \
        --head-sha "$local_sha" \
        --remote-name "$REMOTE_NAME"
    REVIEW_EXIT=$?

    if [ "$REVIEW_EXIT" -ne 0 ]; then
        exit "$REVIEW_EXIT"
    fi
done

exit 0
