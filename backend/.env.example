# Clerk session JWT validation (PR-CL3-2)
CLERK_FAPI_HOST=clerk.<random>.lcl.dev  # dev: fitting-pug-55.clerk.accounts.dev - TODO(post-cluster-3): swap to clerk.<custom-domain>
CLERK_AUDIENCE=                          # leave empty in dev; required in fail-closed envs

# Service-account JWT minting/verification (PR-CL3-2 sections 4.5/4.6)
SERVICE_JWT_SIGNING_KEY=                 # RSA private PEM; dev keypair at .handoffs/cluster-3/service-token-keypair/service.key
SERVICE_JWT_PUBLIC_KEY=                  # RSA public PEM; dev keypair at .handoffs/cluster-3/service-token-keypair/service.pub
BACKEND_SERVICE_ISSUER=https://api.hedge-control.local
BACKEND_SERVICE_AUDIENCE=internal-services
