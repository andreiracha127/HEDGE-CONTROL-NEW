{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(pytest *)",
      "Bash(python *)",
      "Bash(alembic *)"
    ],
    "deny": [
      "Bash(* --force *)",
      "Bash(* --auto *)",
      "Bash(* --no-verify *)",
      "Bash(git push origin main*)",
      "Bash(git push * main*)"
    ]
  }
}
